#include <stdio.h>

struct Process {
    int id;
    int burst;
    int deadline;
};

int main() {
    int n, i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n], temp;


    for(i = 0; i < n; i++) {

        p[i].id = i + 1;

        printf("\nProcess P%d\n", i + 1);

        printf("Enter Burst Time: ");
        scanf("%d", &p[i].burst);

        printf("Enter Deadline: ");
        scanf("%d", &p[i].deadline);
    }


    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {

            if(p[i].deadline > p[j].deadline) {

                temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }


    printf("\nEDF Scheduling Order:\n");

    printf("\nGantt Chart:\n");

    printf("-------------------------------------------------\n");

    for(i = 0; i < n; i++) {
        printf("|  P%d  ", p[i].id);
    }

    printf("|\n");

    printf("-------------------------------------------------\n");


    int time = 0;

    printf("0");

    for(i = 0; i < n; i++) {
        time += p[i].burst;
        printf("      %d", time);
    }

    printf("\n");

    return 0;
}
