#include <stdio.h>

struct Process {
    int id;
    int execution;
    int period;
    int remaining;
};

int main() {
    int n, hyper = 20;
    int i, time;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    struct Process p[n];


    for(i = 0; i < n; i++) {
        p[i].id = i + 1;

        printf("\nProcess P%d\n", i + 1);

        printf("Execution Time: ");
        scanf("%d", &p[i].execution);

        printf("Period: ");
        scanf("%d", &p[i].period);

        p[i].remaining = 0;
    }

    printf("\nGantt Chart:\n");


    for(time = 0; time < hyper; time++) {

        for(i = 0; i < n; i++) {
            if(time % p[i].period == 0) {
                p[i].remaining = p[i].execution;
            }
        }

        int highest = -1;

        for(i = 0; i < n; i++) {
            if(p[i].remaining > 0) {

                if(highest == -1 ||
                   p[i].period < p[highest].period) {
                    highest = i;
                }
            }
        }

        if(highest != -1) {
            printf("| P%d ", p[highest].id);
            p[highest].remaining--;
        }
        else {
            printf("| Idle ");
        }
    }

    printf("|\n");

    for(time = 0; time <= hyper; time++) {
        printf("%-6d", time);
    }

    return 0;
}
