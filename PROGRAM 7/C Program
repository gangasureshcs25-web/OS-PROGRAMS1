#include <stdio.h>

int main() {
    int choice;

    printf("\nPAGE REPLACEMENT ALGORITHMS");
    printf("\n1. FIFO");
    printf("\n2. LRU");
    printf("\n3. Optimal");
    printf("\nEnter your choice: ");
    scanf("%d", &choice);

    int pages[50], frames[10];
    int n, f, i, j;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string: ");
    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &f);

    switch(choice) {

    case 1: { // FIFO
        int k = 0, faults = 0, found;

        for(i = 0; i < f; i++)
            frames[i] = -1;

        for(i = 0; i < n; i++) {
            found = 0;

            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    found = 1;
                    break;
                }
            }

            if(!found) {
                frames[k] = pages[i];
                k = (k + 1) % f;
                faults++;
            }
        }

        printf("Page Faults (FIFO) = %d\n", faults);
        break;
    }

    case 2: { // LRU
        int time[10], count = 0;
        int faults = 0, found, pos;

        for(i = 0; i < f; i++) {
            frames[i] = -1;
            time[i] = 0;
        }

        for(i = 0; i < n; i++) {
            found = 0;

            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    count++;
                    time[j] = count;
                    found = 1;
                    break;
                }
            }

            if(!found) {
                pos = 0;
                for(j = 1; j < f; j++) {
                    if(time[j] < time[pos])
                        pos = j;
                }

                frames[pos] = pages[i];
                count++;
                time[pos] = count;
                faults++;
            }
        }

        printf("Page Faults (LRU) = %d\n", faults);
        break;
    }

    case 3: { // Optimal
        int faults = 0, found, pos, farthest, k;

        for(i = 0; i < f; i++)
            frames[i] = -1;

        for(i = 0; i < n; i++) {
            found = 0;

            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    found = 1;
                    break;
                }
            }

            if(!found) {
                pos = -1;
                farthest = i;

                for(j = 0; j < f; j++) {
                    int next = n;

                    for(k = i + 1; k < n; k++) {
                        if(frames[j] == pages[k]) {
                            next = k;
                            break;
                        }
                    }

                    if(next > farthest) {
                        farthest = next;
                        pos = j;
                    }
                }

                if(pos == -1)
                    pos = 0;

                frames[pos] = pages[i];
                faults++;
            }
        }

        printf("Page Faults (Optimal) = %d\n", faults);
        break;
    }

    default:
        printf("Invalid Choice!\n");
    }

    return 0;
}
