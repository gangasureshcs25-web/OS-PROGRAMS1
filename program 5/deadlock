#include <stdio.h>
#include <stdbool.h>

#define mp 10
#define mr 10

int main()
{
    int n, m;

    printf("Enter no. of Processes: ");
    scanf("%d", &n);

    printf("Enter no. of Resource Types: ");
    scanf("%d", &m);

    int allocation[mp][mr];
    int request[mp][mr];
    int available[mr];

    bool finish[mp];
    int safeSequence[mp];

    printf("\nEnter Allocation Matrix:\n");
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            scanf("%d", &allocation[i][j]);
        }
    }

    printf("\nEnter Request Matrix:\n");
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            scanf("%d", &request[i][j]);
        }
    }

    printf("\nEnter Available Resources:\n");
    for(int j = 0; j < m; j++)
    {
        scanf("%d", &available[j]);
    }

    for(int i = 0; i < n; i++)
    {
        finish[i] = false;
    }

    int count = 0;

    while(count < n)
    {
        bool found = false;

        for(int i = 0; i < n; i++)
        {
            if(!finish[i])
            {
                bool possible = true;

                for(int j = 0; j < m; j++)
                {
                    if(request[i][j] > available[j])
                    {
                        possible = false;
                        break;
                    }
                }

                if(possible)
                {
                    for(int j = 0; j < m; j++)
                    {
                        available[j] += allocation[i][j];
                    }

                    safeSequence[count++] = i;
                    finish[i] = true;
                    found = true;
                }
            }
        }

        if(!found)
            break;
    }

    if(count == n)
    {
        printf("\nNo Deadlock Detected.\n");
        printf("Safe Sequence: ");

        for(int i = 0; i < n; i++)
        {
            printf("P%d", safeSequence[i]);

            if(i != n - 1)
                printf(" -> ");
        }
        printf("\n");
    }
    else
    {
        printf("\nDeadlock Detected!\n");
        printf("Processes involved in deadlock: ");

        for(int i = 0; i < n; i++)
        {
            if(!finish[i])
                printf("P%d ", i);
        }
        printf("\n");
    }

    return 0;
}
