#include <stdio.h>

#define MAX 100

int main() {
    int n, TQ;
    int AT[MAX], BT[MAX], RT[MAX];
    int CT[MAX], WT[MAX], TAT[MAX];
    int queue[MAX], front = 0, rear = 0;
    int visited[MAX] = {0};

    int time = 0, completed = 0;

    // Gantt chart storage
    int gantt_p[MAX * 10];
    int gantt_t[MAX * 10];
    int g = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("Enter Arrival Time and Burst Time for P%d: ", i);
        scanf("%d %d", &AT[i], &BT[i]);
        RT[i] = BT[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &TQ);

    for (int i = 0; i < n; i++) {
        if (AT[i] <= time) {
            queue[rear++] = i;
            visited[i] = 1;
        }
    }

    gantt_t[g] = time;

    while (completed < n) {

        if (front == rear) {
            time++;
            gantt_p[g] = -1;   // idle
            gantt_t[++g] = time;

            for (int i = 0; i < n; i++) {
                if (!visited[i] && AT[i] <= time) {
                    queue[rear++] = i;
                    visited[i] = 1;
                }
            }
            continue;
        }

        int p = queue[front++];

        gantt_p[g] = p;

        if (RT[p] > TQ) {
            time += TQ;
            RT[p] -= TQ;
        }
        else {
            time += RT[p];
            RT[p] = 0;
            CT[p] = time;
            completed++;
        }

        gantt_t[++g] = time;

        for (int i = 0; i < n; i++) {
            if (!visited[i] && AT[i] <= time) {
                queue[rear++] = i;
                visited[i] = 1;
            }
        }

        if (RT[p] > 0) {
            queue[rear++] = p;
        }
    }

    for (int i = 0; i < n; i++) {
        TAT[i] = CT[i] - AT[i];
        WT[i] = TAT[i] - BT[i];
    }

    printf("\nP\tAT\tBT\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", i, AT[i], BT[i], CT[i], TAT[i], WT[i]);
    }


    printf("\nGantt Chart:\n");

    for (int i = 0; i < g; i++) {
        if (gantt_p[i] == -1)
            printf("| Idle ");
        else
            printf("| P%d ", gantt_p[i]);
    }
    printf("|\n");

    for (int i = 0; i <= g; i++) {
        printf("%d     ", gantt_t[i]);
    }
    printf("\n");

    return 0;
}

