#include <stdio.h>

int main() {
    int n, choice;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int bt[n], pr[n], at[n], wt[n], tat[n], ct[n], p[n];

    printf("Enter Arrival Time, Burst Time and Priority:\n");
    for(int i = 0; i < n; i++) {
        printf("P%d AT: ", i+1);
        scanf("%d", &at[i]);

        printf("P%d BT: ", i+1);
        scanf("%d", &bt[i]);

        printf("P%d Priority: ", i+1);
        scanf("%d", &pr[i]);

        p[i] = i + 1;
    }

    printf("\n1. Non-Preemptive Priority\n2. Preemptive Priority\n");
    printf("Enter your choice: ");
    scanf("%d", &choice);

    switch(choice) {


    case 1: {
        int completed = 0, time = 0, min, idx;

        int done[n];
        for(int i = 0; i < n; i++) done[i] = 0;

        while(completed < n) {
            min = 9999;
            idx = -1;

            for(int i = 0; i < n; i++) {
                if(at[i] <= time && !done[i] && pr[i] < min) {
                    min = pr[i];
                    idx = i;
                }
            }

            if(idx != -1) {
                time += bt[idx];
                ct[idx] = time;
                tat[idx] = ct[idx] - at[idx];
                wt[idx] = tat[idx] - bt[idx];

                done[idx] = 1;
                completed++;
            } else {
                time++;
            }
        }

        break;
    }


    case 2: {
        int time = 0, completed = 0, min, idx;

        int rt[n];
        for(int i = 0; i < n; i++)
            rt[i] = bt[i];

        while(completed < n) {
            min = 9999;
            idx = -1;

            for(int i = 0; i < n; i++) {
                if(at[i] <= time && rt[i] > 0 && pr[i] < min) {
                    min = pr[i];
                    idx = i;
                }
            }

            if(idx != -1) {
                rt[idx]--;
                time++;

                if(rt[idx] == 0) {
                    completed++;
                    ct[idx] = time;
                    tat[idx] = ct[idx] - at[idx];
                    wt[idx] = tat[idx] - bt[idx];
                }
            } else {
                time++;
            }
        }

        break;
    }

    default:
        printf("Invalid choice!\n");
        return 0;
    }


    float total_wt = 0, total_tat = 0;

    printf("\nProcess\tAT\tBT\tPriority\tCT\tTAT\tWT\n");
    for(int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t\t%d\t%d\t%d\n",
               p[i], at[i], bt[i], pr[i], ct[i], tat[i], wt[i]);

        total_wt += wt[i];
        total_tat += tat[i];
    }

    printf("\nAverage WT = %.2f", total_wt/n);
    printf("\nAverage TAT = %.2f\n", total_tat/n);

    return 0;
}
